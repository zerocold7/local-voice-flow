# Local Voice Flow Configuration
# Rename this file to .env to apply custom settings

# --- Core AI Settings ---
WHISPER_MODEL_NAME="large-v3"
OLLAMA_HOST_URL="http://127.0.0.1:11434/api/generate"
FALLBACK_LLM="gemma2:27b"
SAMPLE_RATE=16000
CHANNELS=1

# --- Universal Function Keybindings ---
HOTKEY_RAW="f9"
HOTKEY_POLISH="f10"
HOTKEY_TRANSLATE="f11"
HOTKEY_ENGLISH="f8"
HOTKEY_FIX="ctrl+f10"
HOTKEY_MAINTENANCE="ctrl+f11"
HOTKEY_PANIC="esc"

# --- Quality of Life ---
ENABLE_AUDIO_CHIMES="True"
ENABLE_TOAST_NOTIFICATIONS="True"